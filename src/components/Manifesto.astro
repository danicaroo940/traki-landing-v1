---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/ui';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section class="manifesto">
  <div class="container manifesto__inner">
    <p class="eyebrow" data-reveal>{t('manifesto.eyebrow')}</p>
    <h2 class="display-lg manifesto__title" data-reveal>
      {t('manifesto.title')} <span class="accent">{t('manifesto.titleAccent')}</span>
    </h2>
    <div class="manifesto__body">
      <p data-scrub-text>{t('manifesto.body')}</p>
      <p data-scrub-text>{t('manifesto.body2')}</p>
    </div>
  </div>
</section>

<style>
  .manifesto { padding-block: var(--s-12); border-block: 1px solid var(--border-subtle); background: var(--surface-raised); }
  .manifesto__inner { max-width: 900px; }
  .manifesto__title { margin: var(--s-4) 0 var(--s-7); max-width: 18ch; }
  .manifesto__body { display: grid; grid-template-columns: 1fr 1fr; gap: var(--s-8); }
  .manifesto__body p { color: var(--text-secondary); font-size: 18px; line-height: 1.7; margin: 0; }
  @media (max-width: 860px) { .manifesto { padding-block: var(--s-10); } }
  @media (max-width: 720px) { .manifesto__body { grid-template-columns: 1fr; gap: var(--s-5); } }
</style>
