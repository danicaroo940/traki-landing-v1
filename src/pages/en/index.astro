---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Hero from '../../components/Hero.astro';
import Manifesto from '../../components/Manifesto.astro';
import HowItWorks from '../../components/HowItWorks.astro';
import Feature from '../../components/Feature.astro';
import Bento from '../../components/Bento.astro';
import Counters from '../../components/Counters.astro';
import Testimonials from '../../components/Testimonials.astro';
import Faq from '../../components/Faq.astro';
import Waitlist from '../../components/Waitlist.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n/ui';
const lang = 'en' as const;
const t = useTranslations(lang);
---
<Base lang={lang} title="TRAKI — No shortcuts. Just reps." description={t('hero.subtitle')}>
  <Nav lang={lang} />
  <main>
    <Hero lang={lang} />
    <Manifesto lang={lang} />
    <HowItWorks lang={lang} />

    <div id="features" class="section section--tight">
      <div class="container">
        <div class="section__head" data-reveal>
          <p class="eyebrow">{t('feat.eyebrow')}</p>
          <h2 class="display-lg">{t('feat.section.title')} <span class="accent">{t('feat.section.titleAccent')}</span></h2>
        </div>
      </div>
      <Feature eyebrow={t('feat.analyze.eyebrow')} title={t('feat.analyze.title')} titleAccent={t('feat.analyze.titleAccent')} body={t('feat.analyze.body')} bullets={[t('feat.analyze.b1'), t('feat.analyze.b2'), t('feat.analyze.b3')]} src="/screens/screenshot_1.png" alt={t('feat.analyze.eyebrow')} />
      <Feature eyebrow={t('feat.goals.eyebrow')} title={t('feat.goals.title')} titleAccent={t('feat.goals.titleAccent')} body={t('feat.goals.body')} bullets={[t('feat.goals.b1'), t('feat.goals.b2'), t('feat.goals.b3')]} src="/screens/screenshot_2.png" alt={t('feat.goals.eyebrow')} reverse />
      <Feature eyebrow={t('feat.strength.eyebrow')} title={t('feat.strength.title')} titleAccent={t('feat.strength.titleAccent')} body={t('feat.strength.body')} bullets={[t('feat.strength.b1'), t('feat.strength.b2'), t('feat.strength.b3')]} src="/screens/screenshot_3.png" alt={t('feat.strength.eyebrow')} />
      <Feature eyebrow={t('feat.coach.eyebrow')} title={t('feat.coach.title')} titleAccent={t('feat.coach.titleAccent')} body={t('feat.coach.body')} bullets={[t('feat.coach.b1'), t('feat.coach.b2'), t('feat.coach.b3')]} src="/screens/screenshot_4.png" alt={t('feat.coach.eyebrow')} reverse />
    </div>

    <Bento lang={lang} />
    <Counters lang={lang} />
    <Testimonials lang={lang} />
    <Faq lang={lang} />
    <Waitlist lang={lang} />
  </main>
  <Footer lang={lang} />
</Base>
<script>import '../../scripts/animations.ts';</script>
<style>
  /* Each Feature block already carries its own padding-block, so the wrapper's
     bottom padding double-stacks with it against the next section. Drop it and
     keep only the top padding, which gives the section head its lead-in space. */
  #features { padding-bottom: 0; }
</style>
