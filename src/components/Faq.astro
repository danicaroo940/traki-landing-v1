---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/ui';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const items = ['1', '2', '3', '4', '5'];
---
<section id="faq" class="section faq">
  <div class="container faq__inner">
    <div class="section__head section__head--left" data-reveal>
      <p class="eyebrow">{t('faq.eyebrow')}</p>
      <h2 class="display-lg">{t('faq.title')} <span class="accent">{t('faq.titleAccent')}</span></h2>
    </div>
    <div class="faq__list">
      {items.map((i) => (
        <details class="faq__item" data-reveal>
          <summary class="faq__q">
            <span>{t(`faq.${i}.q`)}</span>
            <svg class="faq__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
          </summary>
          <p class="faq__a">{t(`faq.${i}.a`)}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq__inner { max-width: 820px; }
  .faq__list { display: flex; flex-direction: column; gap: var(--s-3); }
  .faq__item {
    background: var(--surface-raised); border: 1px solid var(--border-subtle);
    border-radius: var(--r-xl); padding: 0 var(--s-6);
    transition: border-color var(--dur-med) var(--ease-out);
  }
  .faq__item:hover, .faq__item[open] { border-color: var(--accent); }
  .faq__q {
    display: flex; align-items: center; justify-content: space-between; gap: var(--s-4);
    cursor: pointer; list-style: none; padding: var(--s-5) 0;
    font-family: var(--font-body); font-weight: 600; font-size: 18px; color: var(--text-primary);
  }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__icon { flex-shrink: 0; color: var(--accent); transition: transform var(--dur-med) var(--ease-out); }
  .faq__item[open] .faq__icon { transform: rotate(45deg); }
  .faq__a { color: var(--text-secondary); font-size: 16px; line-height: 1.7; margin: 0; padding: 0 0 var(--s-5); max-width: 68ch; }
</style>
